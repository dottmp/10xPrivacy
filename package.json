{
	"name": "rss-privacy-news",
	"private": true,
	"version": "0.0.1",
	"type": "module",
	"scripts": {
		"dev": "vite dev",
		"dev:cf": "bun run build && wrangler pages dev .svelte-kit/cloudflare",
		"build": "vite build",
		"preview": "vite preview",
		"preview:cf": "wrangler pages dev .svelte-kit/cloudflare",
		"prepare": "svelte-kit sync || echo ''",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"lint": "prettier --check . && eslint .",
		"lint:fix": "eslint --fix .",
		"format": "prettier --write .",
		"fix": "bun run format && bun run lint:fix",
		"test:unit": "vitest",
		"test:watch": "vitest --watch",
		"test": "bun run test:unit",
		"sync:awesome-privacy": "./fetch-awesome-privacy.sh"
	},
	"devDependencies": {
		"@eslint/compat": "^2.0.2",
		"@eslint/js": "^9.39.2",
		"@sveltejs/adapter-auto": "^7.0.0",
		"@sveltejs/adapter-cloudflare": "^7.2.8",
		"@sveltejs/kit": "^2.50.2",
		"@sveltejs/vite-plugin-svelte": "^6.2.4",
		"@tailwindcss/typography": "^0.5.19",
		"@tailwindcss/vite": "^4.1.18",
		"@types/js-yaml": "^4.0.9",
		"@types/node": "^24",
		"daisyui": "^5.5.19",
		"eslint": "^9.39.2",
		"eslint-config-prettier": "^10.1.8",
		"eslint-plugin-check-file": "^3.3.1",
		"eslint-plugin-import": "^2.32.0",
		"eslint-plugin-svelte": "^3.14.0",
		"eslint-plugin-unused-imports": "^4.4.1",
		"globals": "^17.3.0",
		"prettier": "^3.8.1",
		"prettier-plugin-svelte": "^3.4.1",
		"prettier-plugin-tailwindcss": "^0.7.2",
		"svelte": "^5.51.0",
		"svelte-check": "^4.4.2",
		"tailwindcss": "^4.1.18",
		"typescript": "^5.9.3",
		"typescript-eslint": "^8.54.0",
		"vite": "^7.3.1",
		"vitest": "^4.1.0",
		"wrangler": "^4.76.0"
	},
	"dependencies": {
		"isomorphic-dompurify": "^3.4.0",
		"js-yaml": "^4.1.1",
		"marked": "^17.0.5",
		"rss-parser": "^3.13.0",
		"tailwind-merge": "^3.5.0",
		"theme-change": "^2.5.0"
	}
}
